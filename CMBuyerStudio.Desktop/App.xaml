<Application x:Class="CMBuyerStudio.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:CMBuyerStudio.Desktop.ViewModels"
             xmlns:views="clr-namespace:CMBuyerStudio.Desktop.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <ResourceDictionary Source="Resources/Colors.xaml"/>
                <ResourceDictionary Source="Resources/Styles.xaml"/>

            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type viewModels:SearchViewModel}">
                <views:SearchView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModels:WantedCardsViewModel}">
                <views:WantedCardsView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModels:RunBestSellerViewModel}">
                <views:RunBestSellerView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
                <views:SettingsView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewModels:LogsViewModel}">
                <views:LogsView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>