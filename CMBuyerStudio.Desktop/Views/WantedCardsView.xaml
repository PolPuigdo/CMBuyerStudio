<UserControl x:Class="CMBuyerStudio.Desktop.Views.WantedCardsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:CMBuyerStudio.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:WantedCardsViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Style="{StaticResource SectionPanelStyle}"
                Padding="20">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Wanted Cards"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontSize="24"
                               FontWeight="Bold"/>

                    <TextBlock Text="Manage saved card groups, quantities and allowed sets."
                               Margin="0,6,0,0"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontSize="13"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#202635"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12,8"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding TotalGroups}"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <ItemsControl ItemsSource="{Binding Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <!-- GROUP -->
                        <Border Style="{StaticResource SectionPanelStyle}"
                                Padding="18"
                                Margin="0,0,0,16">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- TOP -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- NAME -->
                                    <StackPanel>
                                        <TextBlock Text="{Binding CardName}"
                                                   Foreground="{StaticResource BrushTextPrimary}"
                                                   FontSize="22"
                                                   FontWeight="Bold"/>

                                        <TextBlock Text="Selected variants for this card"
                                                   Margin="0,6,0,0"
                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                   FontSize="13"/>
                                    </StackPanel>

                                    <!-- QUANTITY -->
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                Margin="0,0,18,0">

                                        <TextBlock Text="Desired quantity"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"
                                                   Foreground="{StaticResource BrushTextPrimary}"
                                                   FontWeight="SemiBold"/>

                                        <TextBox Width="72"
                                                 Style="{StaticResource SearchTextBoxStyle}"
                                                 Text="{Binding DesiredQuantity, UpdateSourceTrigger=PropertyChanged}"
                                                 HorizontalContentAlignment="Center"/>
                                    </StackPanel>

                                    <!-- DELETE GROUP -->
                                    <Button Grid.Column="2"
                                            Content="Delete Group"
                                            Command="{Binding DataContext.DeleteGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            MinWidth="130"
                                            Background="#3A2024"
                                            BorderBrush="#6A353D"
                                            Foreground="#FFD7DB"/>
                                </Grid>

                                <!-- VARIANTS -->
                                <ItemsControl Grid.Row="2" ItemsSource="{Binding Variants}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>

                                            <Border Background="#171D29"
                                                    BorderBrush="{StaticResource BrushBorder}"
                                                    BorderThickness="1"
                                                    CornerRadius="12"
                                                    Padding="14"
                                                    Margin="0,0,0,10">

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- SET INFO -->
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding SetName}"
                                                                   Foreground="{StaticResource BrushTextPrimary}"
                                                                   FontSize="16"
                                                                   FontWeight="SemiBold"/>

                                                        <TextBlock Text="{Binding Price, StringFormat=Price preview: {0} €}"
                                                                   Margin="0,4,0,0"
                                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                                   FontSize="13"/>
                                                    </StackPanel>

                                                    <!-- REMOVE -->
                                                    <Button Grid.Column="1"
                                                            Content="Remove"
                                                            Command="{Binding DataContext.RemoveVariantCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            MinWidth="90"
                                                            Padding="12,0"
                                                            Background="#2A2230"
                                                            BorderBrush="#43364D"
                                                            Foreground="{StaticResource BrushTextPrimary}"/>
                                                </Grid>
                                            </Border>

                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </Grid>
                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </ScrollViewer>

        <!-- FOOTER -->
        <Border Grid.Row="4"
                Style="{StaticResource SectionPanelStyle}"
                Padding="18">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Total wanted groups:"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontSize="14"
                               VerticalAlignment="Center"/>

                    <TextBlock Text="{Binding TotalGroups}"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontSize="16"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Clear All Wanted Cards"
                        Command="{Binding ClearAllCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinWidth="200"
                        Background="#3A2024"
                        BorderBrush="#6A353D"
                        Foreground="#FFD7DB"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>