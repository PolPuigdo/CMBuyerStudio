<UserControl x:Class="CMBuyerStudio.Desktop.Views.WantedCardsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Style="{StaticResource SectionPanelStyle}"
                Padding="20">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Wanted Cards"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontSize="24"
                               FontWeight="Bold"/>

                    <TextBlock Text="Manage saved card groups, quantities and allowed sets."
                               Margin="0,6,0,0"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontSize="13"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#202635"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12,8"
                        VerticalAlignment="Center">
                    <TextBlock Text="2 groups"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel>

                <!-- GROUP 1 -->
                <Border Style="{StaticResource SectionPanelStyle}"
                        Padding="18"
                        Margin="0,0,0,16">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- TOP -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Falkenrath Aristocrat"
                                           Foreground="{StaticResource BrushTextPrimary}"
                                           FontSize="22"
                                           FontWeight="Bold"/>

                                <TextBlock Text="Allowed versions selected for this card"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           FontSize="13"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="0,0,18,0">
                                <TextBlock Text="Desired quantity"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"
                                           Foreground="{StaticResource BrushTextPrimary}"
                                           FontWeight="SemiBold"/>

                                <TextBox Width="72"
                                         Style="{StaticResource SearchTextBoxStyle}"
                                         Text="2"
                                         HorizontalContentAlignment="Center"/>
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Content="Delete Group"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    MinWidth="130"
                                    Background="#3A2024"
                                    BorderBrush="#6A353D"
                                    Foreground="#FFD7DB"/>
                        </Grid>

                        <!-- SETS -->
                        <StackPanel Grid.Row="2">

                            <!-- SET ITEM -->
                            <Border Background="#171D29"
                                    BorderBrush="{StaticResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="14"
                                    Margin="0,0,0,10">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="Modern Masters 2017"
                                                   Foreground="{StaticResource BrushTextPrimary}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"/>

                                        <TextBlock Text="Price preview: 0,05 €"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                   FontSize="13"/>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Content="Remove"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            MinWidth="90"
                                            Padding="12,0"
                                            Background="#2A2230"
                                            BorderBrush="#43364D"
                                            Foreground="{StaticResource BrushTextPrimary}"/>
                                </Grid>
                            </Border>

                            <!-- SET ITEM -->
                            <Border Background="#171D29"
                                    BorderBrush="{StaticResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="14"
                                    Margin="0,0,0,10">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="Dark Ascension"
                                                   Foreground="{StaticResource BrushTextPrimary}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"/>

                                        <TextBlock Text="Price preview: 0,15 €"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                   FontSize="13"/>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Content="Remove"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            MinWidth="90"
                                            Padding="12,0"
                                            Background="#2A2230"
                                            BorderBrush="#43364D"
                                            Foreground="{StaticResource BrushTextPrimary}"/>
                                </Grid>
                            </Border>

                            <!-- SET ITEM -->
                            <Border Background="#171D29"
                                    BorderBrush="{StaticResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="14">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="Double Masters"
                                                   Foreground="{StaticResource BrushTextPrimary}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"/>

                                        <TextBlock Text="Price preview: 0,15 €"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                   FontSize="13"/>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Content="Remove"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            MinWidth="90"
                                            Padding="12,0"
                                            Background="#2A2230"
                                            BorderBrush="#43364D"
                                            Foreground="{StaticResource BrushTextPrimary}"/>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </Grid>
                </Border>

                <!-- GROUP 2 -->
                <Border Style="{StaticResource SectionPanelStyle}"
                        Padding="18"
                        Margin="0,0,0,16">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Lightning Bolt"
                                           Foreground="{StaticResource BrushTextPrimary}"
                                           FontSize="22"
                                           FontWeight="Bold"/>

                                <TextBlock Text="Allowed versions selected for this card"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           FontSize="13"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="0,0,18,0">
                                <TextBlock Text="Desired quantity"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"
                                           Foreground="{StaticResource BrushTextPrimary}"
                                           FontWeight="SemiBold"/>

                                <TextBox Width="72"
                                         Style="{StaticResource SearchTextBoxStyle}"
                                         Text="4"
                                         HorizontalContentAlignment="Center"/>
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Content="Delete Group"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    MinWidth="130"
                                    Background="#3A2024"
                                    BorderBrush="#6A353D"
                                    Foreground="#FFD7DB"/>
                        </Grid>

                        <StackPanel Grid.Row="2">
                            <Border Background="#171D29"
                                    BorderBrush="{StaticResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="14"
                                    Margin="0,0,0,10">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="Magic 2010"
                                                   Foreground="{StaticResource BrushTextPrimary}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"/>

                                        <TextBlock Text="Price preview: 1,20 €"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                   FontSize="13"/>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Content="Remove"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            MinWidth="90"
                                            Padding="12,0"
                                            Background="#2A2230"
                                            BorderBrush="#43364D"
                                            Foreground="{StaticResource BrushTextPrimary}"/>
                                </Grid>
                            </Border>

                            <Border Background="#171D29"
                                    BorderBrush="{StaticResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="14">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="Magic 2011"
                                                   Foreground="{StaticResource BrushTextPrimary}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"/>

                                        <TextBlock Text="Price preview: 1,35 €"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                   FontSize="13"/>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                        Content="Remove"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        MinWidth="90"
                                        Padding="12,0"
                                        Background="#2A2230"
                                        BorderBrush="#43364D"
                                        Foreground="{StaticResource BrushTextPrimary}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Grid.Row="4"
                Style="{StaticResource SectionPanelStyle}"
                Padding="18">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Total wanted groups:"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontSize="14"
                               VerticalAlignment="Center"/>

                    <TextBlock Text=" 2"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontSize="16"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Clear All Wanted Cards"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinWidth="200"
                        Background="#3A2024"
                        BorderBrush="#6A353D"
                        Foreground="#FFD7DB"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>