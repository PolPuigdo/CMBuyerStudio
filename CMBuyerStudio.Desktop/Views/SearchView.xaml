<UserControl x:Class="CMBuyerStudio.Desktop.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:CMBuyerStudio.Desktop.Converters">

    <UserControl.Resources>
        <converters:ImagePathToCardImageSourceConverter x:Key="ImagePathToCardImageSourceConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Style="{StaticResource SectionPanelStyle}"
                Padding="20">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Margin="0,0,14,0"
                         Style="{StaticResource SearchTextBoxStyle}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Grid.Column="1"
                    Margin="0,0,14,0"
                    Content="Search"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding SearchCommand}"
                    IsEnabled="{Binding CanSearch}"/>

                <TextBlock Grid.Column="2"
                   Margin="0,0,18,0"
                   VerticalAlignment="Center"
                   Foreground="{StaticResource BrushTextSecondary}"
                   FontSize="13"
                   Text="{Binding ResultsCount, StringFormat={}{0} results, Mode=OneWay}"/>
                
                <Button Grid.Column="3"
                    Content="Select All"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding SelectAllCommand}"
                    IsEnabled="{Binding HasResults}"/>
            </Grid>
        </Border>

        <!-- RESULTS -->
        <ScrollViewer Grid.Row="2"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled">

            <Border Style="{StaticResource SectionPanelStyle}"
            Padding="18"
            Margin="0,4,0,0">

                <StackPanel>
                    <TextBlock Text="Available variants"
                       Style="{StaticResource CardSecondaryTextStyle}"
                       Margin="0,0,0,14"/>

                    <ItemsControl ItemsSource="{Binding Results}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource InteractiveSearchCardStyle}">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding DataContext.ToggleSelectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}" />
                                    </Border.InputBindings>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="14"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Border Style="{StaticResource CardImageContainerStyle}">
                                                <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathToCardImageSourceConverter}}"
                                                   Height="360"
                                                   Stretch="Uniform"/>
                                            </Border>

                                            <Grid Style="{StaticResource SearchCardSelectionOverlayStyle}">
                                                <Viewbox Width="110" Height="110" Margin="0,0,0,100">
                                                    <Grid Width="100" Height="100">
                                                        <Path Style="{StaticResource SearchCardSelectionCheckOutlineStyle}"/>
                                                        <Path Style="{StaticResource SearchCardSelectionCheckStyle}"/>
                                                    </Grid>
                                                </Viewbox>
                                            </Grid>
                                        </Grid>

                                        <StackPanel Grid.Row="2">
                                            <TextBlock Text="{Binding CardName}"
                                               Style="{StaticResource CardTitleTextStyle}"/>

                                            <TextBlock Text="{Binding SetName}"
                                               Margin="0,8,0,0"
                                               Style="{StaticResource CardSecondaryTextStyle}"/>

                                            <TextBlock Margin="0,10,0,0"
                                               Style="{StaticResource CardPriceTextStyle}">
                                        <Run Text="Price "/>
                                        <Run Text="{Binding Price}"/>
                                        <Run Text=" €"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Grid.Row="4"
        Style="{StaticResource SectionPanelStyle}"
        Padding="18">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                    <TextBlock Text="Selected variants:"
                       Foreground="{StaticResource BrushTextSecondary}"
                       FontSize="14"
                       VerticalAlignment="Center"/>

                    <TextBlock Text="{Binding SelectedVariantsCount}"
                       Margin="6,0,0,0"
                       Foreground="{StaticResource BrushTextPrimary}"
                       FontSize="16"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                   Margin="0,0,10,0"
                   VerticalAlignment="Center"
                   Text="Desired quantity"
                   Foreground="{StaticResource BrushTextPrimary}"
                   FontSize="14"
                   FontWeight="SemiBold"/>

                <TextBox Grid.Column="2"
                 Width="72"
                 Margin="0,0,18,0"
                 Style="{StaticResource SearchTextBoxStyle}"
                 Text="{Binding SelectedQuantity, UpdateSourceTrigger=PropertyChanged}"
                 HorizontalContentAlignment="Center"/>

                <Button Grid.Column="3"
                MinWidth="150"
                Content="Save Selection"
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding SaveSelectionCommand}"
                IsEnabled="{Binding CanSaveSelection}"/>
            </Grid>
        </Border>

    </Grid>
</UserControl>