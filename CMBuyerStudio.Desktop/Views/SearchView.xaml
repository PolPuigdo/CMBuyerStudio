<UserControl x:Class="CMBuyerStudio.Desktop.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#161B26"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="20">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Height="44"
                         Margin="0,0,14,0"
                         VerticalContentAlignment="Center"
                         Padding="14,0"
                         Text="Falkenrath Aristocrat"
                         FontSize="15"
                         Background="#101520"
                         Foreground="{StaticResource BrushTextPrimary}"
                         BorderBrush="{StaticResource BrushBorder}"
                         BorderThickness="1"/>

                <Button Grid.Column="1"
                        Height="44"
                        MinWidth="110"
                        Margin="0,0,14,0"
                        Content="Search"
                        Background="{StaticResource BrushAccent}"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Padding="18,0"/>

                <TextBlock Grid.Column="2"
                           Margin="0,0,18,0"
                           VerticalAlignment="Center"
                           Text="3 results"
                           Foreground="{StaticResource BrushTextSecondary}"
                           FontSize="13"/>

                <Button Grid.Column="3"
                        Height="44"
                        MinWidth="110"
                        Content="Select All"
                        Background="#202635"
                        Foreground="{StaticResource BrushTextPrimary}"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="1"
                        FontWeight="SemiBold"
                        Padding="18,0"/>
            </Grid>
        </Border>

        <!-- RESULTS -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <WrapPanel Margin="0,4,0,0">

                <!-- CARD 1 -->
                <Border Width="260"
                        Margin="0,0,18,18"
                        Background="#171D29"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="12">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- IMAGE -->
                        <Grid Grid.Row="0">
                            <Border CornerRadius="12"
                                    ClipToBounds="True"
                                    Background="#0F131C">
                                <Image Source="https://cards.scryfall.io/normal/front/1/0/10b3a5d4.jpg"
                                       Height="360"
                                       Stretch="Uniform"/>
                            </Border>

                            <Border Width="28"
                                    Height="28"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="8"
                                    Background="#990D1016"
                                    CornerRadius="8">
                                <CheckBox HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- INFO -->
                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Falkenrath Aristocrat"
                                       Foreground="{StaticResource BrushTextPrimary}"
                                       FontSize="21"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="Modern Masters 2017"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       FontSize="14"/>

                            <TextBlock Text="Price 0,05 €"
                                       Margin="0,10,0,0"
                                       Foreground="{StaticResource BrushAccent}"
                                       FontSize="18"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- CARD 2 -->
                <Border Width="260"
                        Margin="0,0,18,18"
                        Background="#171D29"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="12">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Border CornerRadius="12"
                                    ClipToBounds="True"
                                    Background="#0F131C">
                                <Image Source="https://cards.scryfall.io/normal/front/1/0/10b3a5d4.jpg"
                                       Height="360"
                                       Stretch="Uniform"/>
                            </Border>

                            <Border Width="28"
                                    Height="28"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="8"
                                    Background="#990D1016"
                                    CornerRadius="8">
                                <CheckBox HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsChecked="True"/>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Falkenrath Aristocrat"
                                       Foreground="{StaticResource BrushTextPrimary}"
                                       FontSize="21"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="Dark Ascension"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       FontSize="14"/>

                            <TextBlock Text="Price 0,15 €"
                                       Margin="0,10,0,0"
                                       Foreground="{StaticResource BrushAccent}"
                                       FontSize="18"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- CARD 3 -->
                <Border Width="260"
                        Margin="0,0,18,18"
                        Background="#171D29"
                        BorderBrush="#4F7DFF"
                        BorderThickness="2"
                        CornerRadius="16"
                        Padding="12">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Border CornerRadius="12"
                                    ClipToBounds="True"
                                    Background="#0F131C">
                                <Image Source="https://cards.scryfall.io/normal/front/1/0/10b3a5d4.jpg"
                                       Height="360"
                                       Stretch="Uniform"/>
                            </Border>

                            <Border Width="28"
                                    Height="28"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="8"
                                    Background="#CC4F7DFF"
                                    CornerRadius="8">
                                <CheckBox HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsChecked="True"/>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Falkenrath Aristocrat"
                                       Foreground="{StaticResource BrushTextPrimary}"
                                       FontSize="21"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="Double Masters"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       FontSize="14"/>

                            <TextBlock Text="Price 0,15 €"
                                       Margin="0,10,0,0"
                                       Foreground="{StaticResource BrushAccent}"
                                       FontSize="18"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </WrapPanel>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Grid.Row="4"
                Background="#161B26"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="18">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Selected variants:"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontSize="14"
                               VerticalAlignment="Center"/>

                    <TextBlock Text=" 2"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontSize="16"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Margin="0,0,10,0"
                           VerticalAlignment="Center"
                           Text="Desired quantity"
                           Foreground="{StaticResource BrushTextPrimary}"
                           FontSize="14"
                           FontWeight="SemiBold"/>

                <TextBox Grid.Column="2"
                         Width="72"
                         Height="38"
                         Margin="0,0,18,0"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Center"
                         Text="2"
                         FontSize="15"
                         Background="#101520"
                         Foreground="{StaticResource BrushTextPrimary}"
                         BorderBrush="{StaticResource BrushBorder}"
                         BorderThickness="1"/>

                <Button Grid.Column="3"
                        Height="40"
                        MinWidth="150"
                        Content="Save Selection"
                        Background="{StaticResource BrushAccent}"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Padding="20,0"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>