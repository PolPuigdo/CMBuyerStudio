<UserControl x:Class="CMBuyerStudio.Desktop.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Style="{StaticResource SectionPanelStyle}"
                Padding="20">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Margin="0,0,14,0"
                         Style="{StaticResource SearchTextBoxStyle}"
                         Text="Falkenrath Aristocrat"/>

                <Button Grid.Column="1"
                        Margin="0,0,14,0"
                        Content="Search"
                        Style="{StaticResource PrimaryButtonStyle}"/>

                <TextBlock Grid.Column="2"
                           Margin="0,0,18,0"
                           VerticalAlignment="Center"
                           Text="3 results"
                           Foreground="{StaticResource BrushTextSecondary}"
                           FontSize="13"/>

                <Button Grid.Column="3"
                        Content="Select All"
                        Style="{StaticResource SecondaryButtonStyle}"/>
            </Grid>
        </Border>

        <!-- RESULTS -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <WrapPanel Margin="0,4,0,0">

                <!-- CARD 1 -->
                <Border Style="{StaticResource HoverSearchCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Border Style="{StaticResource CardImageContainerStyle}">
                                <Image Source="https://cards.scryfall.io/normal/front/1/0/10b3a5d4.jpg"
                                       Height="360"
                                       Stretch="Uniform"/>
                            </Border>

                            <Border HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="8"
                                    Style="{StaticResource CardOverlayChipStyle}">
                                <CheckBox HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Falkenrath Aristocrat"
                                       Style="{StaticResource CardTitleTextStyle}"/>

                            <TextBlock Text="Modern Masters 2017"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource CardSecondaryTextStyle}"/>

                            <TextBlock Text="Price 0,05 €"
                                       Margin="0,10,0,0"
                                       Style="{StaticResource CardPriceTextStyle}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- CARD 2 -->
                <Border Style="{StaticResource HoverSearchCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Border Style="{StaticResource CardImageContainerStyle}">
                                <Image Source="https://cards.scryfall.io/normal/front/1/0/10b3a5d4.jpg"
                                       Height="360"
                                       Stretch="Uniform"/>
                            </Border>

                            <Border HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="8"
                                    Style="{StaticResource CardOverlayChipStyle}">
                                <CheckBox HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsChecked="True"/>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Falkenrath Aristocrat"
                                       Style="{StaticResource CardTitleTextStyle}"/>

                            <TextBlock Text="Dark Ascension"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource CardSecondaryTextStyle}"/>

                            <TextBlock Text="Price 0,15 €"
                                       Margin="0,10,0,0"
                                       Style="{StaticResource CardPriceTextStyle}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- CARD 3 SELECTED -->
                <Border Style="{StaticResource HoverSelectedSearchCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Border Style="{StaticResource CardImageContainerStyle}">
                                <Image Source="https://cards.scryfall.io/normal/front/1/0/10b3a5d4.jpg"
                                       Height="360"
                                       Stretch="Uniform"/>
                            </Border>

                            <Border HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="8"
                                    Style="{StaticResource SelectedCardOverlayChipStyle}">
                                <CheckBox HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsChecked="True"/>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Falkenrath Aristocrat"
                                       Style="{StaticResource CardTitleTextStyle}"/>

                            <TextBlock Text="Double Masters"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource CardSecondaryTextStyle}"/>

                            <TextBlock Text="Price 0,15 €"
                                       Margin="0,10,0,0"
                                       Style="{StaticResource CardPriceTextStyle}"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </WrapPanel>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Grid.Row="4"
                Style="{StaticResource SectionPanelStyle}"
                Padding="18">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Selected variants:"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontSize="14"
                               VerticalAlignment="Center"/>

                    <TextBlock Text=" 2"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontSize="16"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Margin="0,0,10,0"
                           VerticalAlignment="Center"
                           Text="Desired quantity"
                           Foreground="{StaticResource BrushTextPrimary}"
                           FontSize="14"
                           FontWeight="SemiBold"/>

                <TextBox Grid.Column="2"
                         Width="72"
                         Margin="0,0,18,0"
                         Style="{StaticResource SearchTextBoxStyle}"
                         Text="2"
                         HorizontalContentAlignment="Center"/>

                <Button Grid.Column="3"
                        MinWidth="150"
                        Content="Save Selection"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>