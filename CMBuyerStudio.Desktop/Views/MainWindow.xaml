<Window x:Class="CMBuyerStudio.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:feedback="clr-namespace:CMBuyerStudio.Desktop.Feedback"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="CMBuyerStudio"
        Height="900"
        Width="1400"
        Icon="/Assets/CMBuyerStudio_ICON.ico"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="{StaticResource BrushBackgroundMain}"
        StateChanged="OnWindowStateChanged">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="42"
                            ResizeBorderThickness="8"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Border Grid.Row="0"
                Background="{StaticResource BrushSidebar}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="CMBuyerStudio"
                           Margin="14,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource BrushTextPrimary}"
                           FontSize="14"
                           FontWeight="SemiBold"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <Button Content="&#xE921;"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="OnMinimizeButtonClick"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>

                    <Button x:Name="MaximizeRestoreButton"
                            Content="&#xE922;"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="OnMaximizeRestoreButtonClick"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>

                    <Button Content="&#xE8BB;"
                            Style="{StaticResource TitleBarCloseButtonStyle}"
                            Click="OnCloseButtonClick"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0"
                    Background="{StaticResource BrushSidebar}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="0,0,1,0">

                <StackPanel VerticalAlignment="Center">

                    <Button Content="&#x1F50D;"
                            Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding ShowSearchCommand}"/>

                    <Button Content="&#x1F0CF;"
                            Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding ShowWantedCardsCommand}"/>

                    <Button Content="&#x25B6;"
                            Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding ShowRunBestSellerCommand}"/>

                    <Button Content="&#x2699;"
                            Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding ShowSettingsCommand}"/>

                    <Button Content="&#x1F4C4;"
                            Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding ShowLogsCommand}"/>

                </StackPanel>
            </Border>

            <!-- CONTENT -->
            <Grid Grid.Column="1" Margin="20">
                <Border Background="{StaticResource BrushSurface}"
                        CornerRadius="12"
                        Padding="20">

                    <ContentControl Content="{Binding CurrentViewModel}"/>

                </Border>
            </Grid>
        </Grid>

        <!-- TOAST -->
        <Border Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,24,0,0"
                Padding="16,11"
                CornerRadius="10"
                BorderThickness="1"
                Panel.ZIndex="999"
                IsHitTestVisible="False">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Setter Property="Background" Value="#1F2E24"/>
                    <Setter Property="BorderBrush" Value="#2D7A46"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsToastVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ToastKind}" Value="{x:Static feedback:ToastNotificationKind.Success}">
                            <Setter Property="Background" Value="#1F2E24"/>
                            <Setter Property="BorderBrush" Value="#2D7A46"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <TextBlock Text="{Binding ToastMessage}"
                       Foreground="#E6FFE9"
                       FontSize="13"
                       FontWeight="SemiBold"/>
        </Border>

    </Grid>
</Window>
