<Window x:Class="CMBuyerStudio.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CMBuyerStudio"
        Height="900"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushBackgroundMain}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="{StaticResource BrushSidebar}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,0,1,0">

            <StackPanel VerticalAlignment="Center">

                <Button Content="🔍"
                        Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding ShowSearchCommand}"/>

                <Button Content="🃏"
                        Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding ShowWantedCardsCommand}"/>

                <Button Content="▶"
                        Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding ShowRunBestSellerCommand}"/>

                <Button Content="⚙"
                        Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding ShowSettingsCommand}"/>

                <Button Content="📄"
                        Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding ShowLogsCommand}"/>

            </StackPanel>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Column="1" Margin="20">
            <Border Background="{StaticResource BrushSurface}"
                    CornerRadius="12"
                    Padding="20">

                <ContentControl Content="{Binding CurrentViewModel}"/>

            </Border>
        </Grid>

    </Grid>
</Window>