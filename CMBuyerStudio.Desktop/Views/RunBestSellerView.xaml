<UserControl x:Class="CMBuyerStudio.Desktop.Views.RunBestSellerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:CMBuyerStudio.Desktop.Converters"
             xmlns:viewModels="clr-namespace:CMBuyerStudio.Desktop.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:RunBestSellerViewModel}">

    <UserControl.Resources>
        <converters:StepArrowVisibilityConverter x:Key="StepArrowVisibilityConverter"/>

        <!-- Progress bar -->
        <Style x:Key="RunProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="18"/>
            <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
            <Setter Property="Background" Value="#101520"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                SnapsToDevicePixels="True">
                            <Grid ClipToBounds="True">
                                <Border x:Name="PART_Track"
                                        Background="Transparent"
                                        CornerRadius="9"/>

                                <Border x:Name="PART_Indicator"
                                        HorizontalAlignment="Left"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="9"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Step card -->
        <Style x:Key="RunStepCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#171D29"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Small status pill -->
        <Style x:Key="StepStatusBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#202635"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <!-- Soft info panel -->
        <Style x:Key="RunInfoPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="#171D29"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

    </UserControl.Resources>

    <Grid Background="{StaticResource BrushBackgroundMain}">
        <Grid.RowDefinitions>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="24"/>
        </Grid.ColumnDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="1"
                Grid.Column="1"
                Style="{StaticResource SectionPanelStyle}"
                Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Run Best Seller"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontSize="22"
                               FontWeight="Bold"/>

                    <TextBlock Text="Run the scraping and optimization process to find the best seller combinations for your wanted cards."
                               Margin="0,6,0,0"
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontSize="13"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#202635"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12,8"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding TotalWantedCardsText}"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <Border Grid.Row="3"
                Grid.Column="1"
                Style="{StaticResource SectionPanelStyle}"
                Padding="22">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- TOP ACTIONS -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Execution"
                                   Foreground="{StaticResource BrushTextPrimary}"
                                   FontSize="20"
                                   FontWeight="Bold"/>

                        <TextBlock Text="Start the run when your wanted cards list is ready. You can cancel the execution at any time."
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="{Binding RunButtonText}"
                            Command="{Binding RunCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            MinWidth="230"
                            IsEnabled="{Binding CanRun}"/>

                    <Button Grid.Column="3"
                            Content="Cancel Execution"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="170"
                            IsEnabled="{Binding CanCancel}"
                            Background="#3A2024"
                            BorderBrush="#6A353D"
                            Foreground="#FFD7DB"/>
                </Grid>

                <!-- PROGRESS -->
                <Border Grid.Row="2"
                        Style="{StaticResource RunInfoPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Progress"
                                       Foreground="{StaticResource BrushTextPrimary}"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding ProgressText}"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <ProgressBar Grid.Row="2"
                                     Style="{StaticResource RunProgressBarStyle}"
                                     Minimum="0"
                                     Maximum="{Binding ProgressMaximum}"
                                     Value="{Binding ProgressValue}"/>

                        <StackPanel Grid.Row="4">
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="{StaticResource BrushTextPrimary}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="{Binding DetailText}"
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- STEPS -->
                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Steps}"
                                      AlternationCount="128">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Style="{StaticResource RunStepCardStyle}"
                                                Width="220">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="{StaticResource BrushTextPrimary}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap"/>

                                                <Border Grid.Column="2"
                                                        Style="{StaticResource StepStatusBadgeStyle}"
                                                        Background="{Binding StatusBackground}"
                                                        BorderBrush="{Binding StatusBorderBrush}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding StatusText}"
                                                               Foreground="{Binding StatusForeground}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <TextBlock Text="→"
                                                   Margin="10,0,10,12"
                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Visibility>
                                                <MultiBinding Converter="{StaticResource StepArrowVisibilityConverter}">
                                                    <Binding RelativeSource="{RelativeSource AncestorType=ContentPresenter}"
                                                             Path="(ItemsControl.AlternationIndex)"/>
                                                    <Binding RelativeSource="{RelativeSource AncestorType=ItemsControl}"
                                                             Path="Items.Count"/>
                                                </MultiBinding>
                                            </TextBlock.Visibility>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- SMALL SUMMARY -->
                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource RunInfoPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="EU calculation"
                                       Foreground="{StaticResource BrushTextPrimary}"
                                       FontSize="15"
                                       FontWeight="SemiBold"/>

                            <TextBlock Text="{Binding EuSummaryText}"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource RunInfoPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Local calculation"
                                       Foreground="{StaticResource BrushTextPrimary}"
                                       FontSize="15"
                                       FontWeight="SemiBold"/>

                            <TextBlock Text="{Binding LocalSummaryText}"
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource BrushTextSecondary}"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- REPORTS -->
                <Border Grid.Row="8"
                        Style="{StaticResource RunInfoPanelStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Generated reports"
                                       Foreground="{StaticResource BrushTextPrimary}"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Open EU Report"
                                Command="{Binding OpenEuReportCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="150"
                                IsEnabled="{Binding CanOpenEuReport}"/>

                        <Button Grid.Column="3"
                                Content="Open Local Report"
                                Command="{Binding OpenLocalReportCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="160"
                                IsEnabled="{Binding CanOpenLocalReport}"/>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Grid>
</UserControl>
