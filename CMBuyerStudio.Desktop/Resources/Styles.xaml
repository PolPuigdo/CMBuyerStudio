<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Sidebar Button -->
    <Style x:Key="SidebarButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="56"/>
        <Setter Property="Height" Value="56"/>
        <Setter Property="Margin" Value="10"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Border"
                            CornerRadius="10"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>

                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#1F2633"/>
                            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                        </Trigger>

                        <!-- Pressed -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#2A3140"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Title Bar Button -->
    <Style x:Key="TitleBarButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="48"/>
        <Setter Property="Height" Value="42"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#1F2633"/>
                            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#2A3140"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Title Bar Close Button -->
    <Style x:Key="TitleBarCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#8A2C35"/>
                            <Setter Property="Foreground" Value="#FFE7EA"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#6D232B"/>
                            <Setter Property="Foreground" Value="#FFE7EA"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Primary Button -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="42"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="Padding" Value="18,0"/>
        <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Border"
                        Background="{TemplateBinding Background}"
                        CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#5A96E0"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#4A82C7"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Secondary Button -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="42"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="Padding" Value="18,0"/>
        <Setter Property="Background" Value="#202635"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#262D3D"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#2E374A"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Search TextBox -->
    <Style x:Key="SearchTextBoxStyle" TargetType="TextBox">
        <Setter Property="Height" Value="44"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Background" Value="#101520"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- Scrollbar -->
    <Style x:Key="AppScrollBarThumbStyle" TargetType="Thumb">
        <Setter Property="Background" Value="#3A4B69"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#4C648E"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#6EA8FE"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Danger Button -->
    <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
        <Setter Property="Background" Value="#3A2024"/>
        <Setter Property="BorderBrush" Value="#6A353D"/>
        <Setter Property="Foreground" Value="#FFD7DB"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#4A282E"/>
                            <Setter TargetName="Border" Property="BorderBrush" Value="#7C3D46"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#5A3037"/>
                            <Setter TargetName="Border" Property="BorderBrush" Value="#8F4651"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AppScrollBarTrackButtonStyle" TargetType="RepeatButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Rectangle Fill="{TemplateBinding Background}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="AppVerticalScrollBarTemplate" TargetType="ScrollBar">
        <Border Background="#101520"
                CornerRadius="6"
                Padding="1">
            <Track x:Name="PART_Track"
                   IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                  Style="{StaticResource AppScrollBarTrackButtonStyle}"/>
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource AppScrollBarThumbStyle}"
                           MinHeight="28"/>
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                  Style="{StaticResource AppScrollBarTrackButtonStyle}"/>
                </Track.IncreaseRepeatButton>
            </Track>
        </Border>
    </ControlTemplate>

    <ControlTemplate x:Key="AppHorizontalScrollBarTemplate" TargetType="ScrollBar">
        <Border Background="#101520"
                CornerRadius="6"
                Padding="1">
            <Track x:Name="PART_Track"
                   IsDirectionReversed="False">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageLeftCommand"
                                  Style="{StaticResource AppScrollBarTrackButtonStyle}"/>
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource AppScrollBarThumbStyle}"
                           MinWidth="28"/>
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageRightCommand"
                                  Style="{StaticResource AppScrollBarTrackButtonStyle}"/>
                </Track.IncreaseRepeatButton>
            </Track>
        </Border>
    </ControlTemplate>

    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="12"/>
        <Setter Property="Background" Value="#101520"/>
        <Setter Property="Template" Value="{StaticResource AppVerticalScrollBarTemplate}"/>
        <Setter Property="Margin" Value="4,0,0,0"/>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="12"/>
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Margin" Value="0,4,0,0"/>
                <Setter Property="Template" Value="{StaticResource AppHorizontalScrollBarTemplate}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Section Panel -->
    <Style x:Key="SectionPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="#161B26"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
    </Style>

    <!-- Dialog Panel -->
    <Style x:Key="DialogPanelStyle" TargetType="Border" BasedOn="{StaticResource SectionPanelStyle}">
        <Setter Property="CornerRadius" Value="12"/>
    </Style>

    <!-- Card Border -->
    <Style x:Key="SearchCardStyle" TargetType="Border">
        <Setter Property="Width" Value="260"/>
        <Setter Property="Margin" Value="0,0,18,18"/>
        <Setter Property="Background" Value="#171D29"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="12"/>
    </Style>

    <!-- Selected Card Border -->
    <Style x:Key="SelectedSearchCardStyle" TargetType="Border" BasedOn="{StaticResource SearchCardStyle}">
        <Setter Property="BorderBrush" Value="#4F7DFF"/>
        <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <!-- Card Image Host -->
    <Style x:Key="CardImageContainerStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="ClipToBounds" Value="True"/>
        <Setter Property="Background" Value="#0F131C"/>
    </Style>

    <!-- Card Title -->
    <Style x:Key="CardTitleTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="FontSize" Value="21"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- Card Secondary Text -->
    <Style x:Key="CardSecondaryTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- Card Price Text -->
    <Style x:Key="CardPriceTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- Small overlay chip -->
    <Style x:Key="CardOverlayChipStyle" TargetType="Border">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Background" Value="#990D1016"/>
    </Style>

    <!-- Selected overlay chip -->
    <Style x:Key="SelectedCardOverlayChipStyle" TargetType="Border" BasedOn="{StaticResource CardOverlayChipStyle}">
        <Setter Property="Background" Value="#CC4F7DFF"/>
    </Style>

    <!-- Hoverable Search Card -->
    <Style x:Key="HoverSearchCardStyle" TargetType="Border" BasedOn="{StaticResource SearchCardStyle}">
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="#3A455C"/>
                <Setter Property="Background" Value="#1B2230"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Hoverable Selected Search Card -->
    <Style x:Key="HoverSelectedSearchCardStyle" TargetType="Border" BasedOn="{StaticResource SelectedSearchCardStyle}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#1B2230"/>
                <Setter Property="BorderBrush" Value="#6A93FF"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Interactable card selection search -->
    <Style x:Key="InteractiveSearchCardStyle"
   TargetType="Border"
   BasedOn="{StaticResource SearchCardStyle}">
        <Setter Property="Cursor" Value="Hand"/>

        <Style.Triggers>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                <Setter Property="BorderThickness" Value="3"/>
                <Setter Property="Background" Value="#1B2230"/>
            </DataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                    <Condition Binding="{Binding IsSelected}" Value="False"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="BorderBrush" Value="#3A455C"/>
                <Setter Property="Background" Value="#1B2230"/>
            </MultiDataTrigger>

            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                    <Condition Binding="{Binding IsSelected}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="BorderBrush" Value="#6A93FF"/>
                <Setter Property="Background" Value="#1B2230"/>
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Checkbox selection search -->
    <Geometry x:Key="SearchCardSelectionCheckGeometry">
        M 16 54 L 40 78 L 84 24
    </Geometry>

    <Style x:Key="SearchCardSelectionOverlayStyle" TargetType="Grid">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Panel.ZIndex" Value="2"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
        <Setter Property="Visibility" Value="Collapsed"/>

        <Style.Triggers>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter Property="Visibility" Value="Visible"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SearchCardSelectionCheckOutlineStyle" TargetType="Path">
        <Setter Property="Data" Value="{StaticResource SearchCardSelectionCheckGeometry}"/>
        <Setter Property="Stroke" Value="{StaticResource BrushSelectionCheckOutline}"/>
        <Setter Property="StrokeThickness" Value="18"/>
        <Setter Property="StrokeStartLineCap" Value="Round"/>
        <Setter Property="StrokeEndLineCap" Value="Round"/>
        <Setter Property="StrokeLineJoin" Value="Round"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="SearchCardSelectionCheckStyle"
       TargetType="Path"
       BasedOn="{StaticResource SearchCardSelectionCheckOutlineStyle}">
        <Setter Property="Stroke" Value="{StaticResource BrushSelectionCheck}"/>
        <Setter Property="StrokeThickness" Value="10"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>

</ResourceDictionary>
