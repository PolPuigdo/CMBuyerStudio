<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <Color x:Key="ColorBackgroundMain">#12141A</Color>
    <Color x:Key="ColorBackgroundSidebar">#0D1016</Color>
    <Color x:Key="ColorSurface">#1B1F2A</Color>

    <!-- Borders -->
    <Color x:Key="ColorBorder">#2A3140</Color>

    <!-- Text -->
    <Color x:Key="ColorTextPrimary">#F3F4F6</Color>
    <Color x:Key="ColorTextSecondary">#AAB2C0</Color>

    <!-- Accent -->
    <Color x:Key="ColorAccent">#6EA8FE</Color>
    <Color x:Key="ColorAccentHover">#5A96E0</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BrushBackgroundMain" Color="{StaticResource ColorBackgroundMain}"/>
    <SolidColorBrush x:Key="BrushSidebar" Color="{StaticResource ColorBackgroundSidebar}"/>
    <SolidColorBrush x:Key="BrushSurface" Color="{StaticResource ColorSurface}"/>
    <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource ColorBorder}"/>
    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorTextPrimary}"/>
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ColorTextSecondary}"/>
    <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorAccent}"/>

</ResourceDictionary>